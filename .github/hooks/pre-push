#!/bin/sh
# main ブランチへの直接 push を禁止する

protected_branch="refs/heads/main"

while read local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "$protected_branch" ]; then
    echo "❌ main ブランチへの直接 push は禁止されています。"
    echo ""
    echo "   必ず feature/* / fix/* 等のブランチを作成し、PR 経由でマージしてください。"
    echo ""
    echo "   例: git checkout -b feature/#N-description"
    echo ""
    exit 1
  fi
done

exit 0
