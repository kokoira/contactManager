#!/bin/sh
# main ブランチへの直接 push を禁止する

protected_branch="main"
current_branch=$(git symbolic-ref HEAD 2>/dev/null | sed 's|refs/heads/||')

if [ "$current_branch" = "$protected_branch" ]; then
  echo "❌ main ブランチへの直接 push は禁止されています。"
  echo ""
  echo "   必ず feature/* / fix/* 等のブランチを作成し、PR 経由でマージしてください。"
  echo ""
  echo "   例: git checkout -b feature/#N-description"
  echo ""
  exit 1
fi

exit 0
